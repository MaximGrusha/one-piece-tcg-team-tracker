// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  email        String   @unique
  passwordHash String
  displayName  String
  role         Role     @default(MEMBER)

  borrows      Borrow[]
  activityLogs ActivityLog[]
}

model CardSet {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  code        String   @unique   // e.g. "OP01", "ST01"
  name        String
  type        SetType  @default(BOOSTER)
  releaseDate DateTime?
  imageUrl    String?
  cardCount   Int      @default(0)

  cards       Card[]
}

model Card {
  id              String        @id @default(cuid())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  name            String
  setCode         String        // e.g. OP01-001
  imageUrl        String?
  rarity          Rarity
  color           Color
  totalQuantity   Int
  availableQuantity Int
  notes           String?

  cardType        String?       // Leader, Character, Event, Stage
  cost            Int?
  power           Int?
  counter          Int?
  attribute       String?
  cardText        String?

  marketPrice     Float?        // USD from OPTCG API
  inventoryPrice  Float?        // USD from OPTCG API
  priceUpdatedAt  DateTime?     // last price sync

  setId           String?
  set             CardSet?      @relation(fields: [setId], references: [id])

  borrowItems     BorrowItem[]

  @@unique([setCode])
}

model Borrow {
  id          String        @id @default(cuid())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  borrowerName String
  userId       String?
  user         User?        @relation(fields: [userId], references: [id])
  status       BorrowStatus @default(ACTIVE)
  borrowedAt   DateTime     @default(now())
  returnedAt   DateTime?

  items        BorrowItem[]
}

model BorrowItem {
  id        String   @id @default(cuid())
  card      Card     @relation(fields: [cardId], references: [id])
  cardId    String

  borrow    Borrow   @relation(fields: [borrowId], references: [id])
  borrowId  String

  quantity  Int
}

enum Role {
  ADMIN
  MEMBER
}

enum Rarity {
  COMMON
  UNCOMMON
  RARE
  SUPER_RARE
  SECRET_RARE
  LEADER
}

enum Color {
  RED
  BLUE
  GREEN
  PURPLE
  BLACK
  YELLOW
  MULTICOLOR
}

enum BorrowStatus {
  ACTIVE
  RETURNED
}

enum SetType {
  BOOSTER
  STARTER_DECK
  PROMO
}

model ActivityLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  action    String            // CARD_CREATED, CARD_DELETED, BORROW_CREATED, BORROW_RETURNED, USER_CREATED, USER_DELETED, PRICES_REFRESHED, SET_IMPORTED
  details   String?           // JSON or human-readable detail
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
}
