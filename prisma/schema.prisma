// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Card {
  id              String        @id @default(cuid())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  name            String
  setCode         String        // e.g. OP01-001
  imageUrl        String?
  rarity          Rarity
  color           Color
  totalQuantity   Int
  availableQuantity Int
  notes           String?

  borrowItems     BorrowItem[]

  @@unique([setCode])
}

model Borrow {
  id          String        @id @default(cuid())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  borrowerName String
  status       BorrowStatus @default(ACTIVE)
  borrowedAt   DateTime     @default(now())
  returnedAt   DateTime?

  items        BorrowItem[]
}

model BorrowItem {
  id        String   @id @default(cuid())
  card      Card     @relation(fields: [cardId], references: [id])
  cardId    String

  borrow    Borrow   @relation(fields: [borrowId], references: [id])
  borrowId  String

  quantity  Int
}

enum Rarity {
  COMMON
  UNCOMMON
  RARE
  SUPER_RARE
  SECRET_RARE
  LEADER
}

enum Color {
  RED
  BLUE
  GREEN
  PURPLE
  BLACK
  YELLOW
  MULTICOLOR
}

enum BorrowStatus {
  ACTIVE
  RETURNED
}
